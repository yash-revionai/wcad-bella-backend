{
  "name": "wcad-bella-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:vercel": "cd admin && npm run build && cd .. && rm -rf .next && cp -R admin/.next .next",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "ADMIN_API_KEY=test-admin-api-key node --test dist/test/**/*.test.js",
    "seed": "tsx database/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.87.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "luxon": "^3.7.2",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.3",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
